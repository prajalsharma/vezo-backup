# ─────────────────────────────────────────────────────────────────────────────
# Mezo MAINNET deploy of the v2 modules (VeNFTBidding fix + SwapPaymentRouter).
#
# Usage:
#   1. cp .env.mainnet.example .env
#   2. fill the three secrets below (DEPLOYER_PRIVATE_KEY / ADMIN_ADDRESS / FEE_RECIPIENT)
#   3. npx hardhat run scripts/deploy-v2-modules.ts --network mezomainnet
#
# This reuses every existing core + module contract and only deploys a fresh
# VeNFTBidding (the acceptBid fix) and a fresh SwapPaymentRouter (the real swap).
# ─────────────────────────────────────────────────────────────────────────────

# ── YOU MUST FILL THESE ──
DEPLOYER_PRIVATE_KEY=0x__YOUR_DEPLOYER_KEY__   # wallet that pays gas — needs BTC on Mezo mainnet
ADMIN_ADDRESS=0x__YOUR_ADMIN__                 # admin/owner stored on the new contracts (your wallet or multisig)
FEE_RECIPIENT=0x__YOUR_FEE_RECEIVER__          # receives swap fees

# ── Optional ──
MAINNET_RPC_URL=https://mainnet.mezo.public.validationcloud.io   # working public RPC (rpc.mezo.org is dead); alts: https://mezo.drpc.org
SWAP_PLATFORM_FEE_BPS=50                        # SwapPaymentRouter fee, bps (<=100). 50 = 0.5%

# ── Reuse existing live contracts (do NOT change these) ──
EXISTING_MARKETPLACE=0x293ba099c5Cf32af54013F00fEe8D2EA1cad8570
EXISTING_ADAPTER=0x8EC595099030aB282511c87cAF104E734418Eff5
EXISTING_ROUTER=0xA4098F23aA2883DA13A714982d89BFB403718fb9
EXISTING_ADMIN_CONTRACT=0x5bBc2d83D0786Bf2Bc56096d832e6B7cfcca9396
EXISTING_ORACLE_HUB=0x8bE4D741353b0B7724153B25F772a595bDA2C588
EXISTING_QUOTE_ROUTER=0x7ED3d6793273f434851385854d2779d20c90b3A5
EXISTING_SNAPSHOT_STORE=0xffCE94434A5b4b0C21a66C0E0183345452AA5424

# Velodrome PoolFactory on Mezo (used by SwapPaymentRouter for BTC<->MUSD swaps).
# The deploy script already defaults to this on mainnet; set it only to override.
POOL_FACTORY=0x83FE469C636C4081b87bA5b3Ae9991c6Ed104248

# NOTE: deliberately do NOT set EXISTING_BIDDING — leaving it unset forces a fresh
# VeNFTBidding deploy (the one with the acceptBid self-routing fix).
