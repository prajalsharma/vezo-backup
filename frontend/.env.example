# Mezo veNFT Marketplace — Frontend Environment Variables
# Copy to .env.local and fill in values after contract deployment.
# NEVER commit real secrets.

# WalletConnect Project ID — get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_ID=your_walletconnect_project_id

# ── Testnet Deployments (Chain ID: 31611) ──────────────────────────────────
# Fill these in after running: npx hardhat run scripts/deploy-testnet.ts --network mezotestnet
NEXT_PUBLIC_MARKETPLACE_TESTNET=your_testnet_marketplace_address
NEXT_PUBLIC_ADAPTER_TESTNET=your_testnet_adapter_address
NEXT_PUBLIC_ROUTER_TESTNET=your_testnet_router_address
NEXT_PUBLIC_ADMIN_TESTNET=your_testnet_admin_address

# ── Mainnet Deployments (Chain ID: 31612) ──────────────────────────────────
# Fill these in after running: npx hardhat run scripts/deploy-mainnet.ts --network mezomainnet
NEXT_PUBLIC_MARKETPLACE_MAINNET=your_mainnet_marketplace_address
NEXT_PUBLIC_ADAPTER_MAINNET=your_mainnet_adapter_address
NEXT_PUBLIC_ROUTER_MAINNET=your_mainnet_router_address
NEXT_PUBLIC_ADMIN_MAINNET=your_mainnet_admin_address

# ── Token Addresses (same on both networks) ────────────────────────────────
# These have fixed addresses on Mezo — only override if using a fork.
# NEXT_PUBLIC_BTC_ADDRESS=0x7b7c000000000000000000000000000000000000
# NEXT_PUBLIC_MEZO_ADDRESS=0x7b7c000000000000000000000000000000000001

# ── veNFT Addresses ────────────────────────────────────────────────────────
# Testnet
# NEXT_PUBLIC_VEBTC_TESTNET=0x38E35d92E6Bfc6787272A62345856B13eA12130a
# NEXT_PUBLIC_VEMEZO_TESTNET=0xaCE816CA2bcc9b12C59799dcC5A959Fb9b98111b
# Mainnet
# NEXT_PUBLIC_VEBTC_MAINNET=0x3D4b1b884A7a1E59fE8589a3296EC8f8cBB6f279
# NEXT_PUBLIC_VEMEZO_MAINNET=0xb90fdAd3DFD180458D62Cc6acedc983D78E20122

# ── MUSD Stablecoin ────────────────────────────────────────────────────────
# NEXT_PUBLIC_MUSD_TESTNET=0x118917a40FAF1CD7a13dB0Ef56C86De7973Ac503
